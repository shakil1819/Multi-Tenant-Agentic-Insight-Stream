# ── App ──
PORT=3000
NODE_ENV=development

# ── OpenAI ──
OPENAI_API_KEY=sk-mock-replace-with-real-key
OPENAI_MODEL=gpt-4o-mini

# ── Weaviate ──
WEAVIATE_URL=http://localhost:8080
WEAVIATE_GRPC_PORT=50051
WEAVIATE_COLLECTION=TenantQaChunk

# ── LangSmith Tracing ──
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2-mock-replace-with-real-key
LANGSMITH_PROJECT=agentic-rag-chartjs
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
